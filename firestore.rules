rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the path ID is valid
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /invoices/{invoiceId} {
      allow read, write: if isValidId(invoiceId);
    }

    match /employees/{employeeId} {
      allow read, write: if isValidId(employeeId);
    }

    match /notes/{noteId} {
      allow read, write: if isValidId(noteId);
    }
    
    // Default fallback deny rule
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
